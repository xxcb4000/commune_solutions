{
  "screen": "main",
  "navigation": {
    "title": "Hello World",
    "displayMode": "large"
  },
  "data": {
    "items": "module:sample"
  },
  "view": {
    "type": "scroll",
    "children": [
      {
        "type": "vstack",
        "spacing": 16,
        "padding": 16,
        "children": [
          {
            "type": "header",
            "title": "Bienvenue dans votre module",
            "subtitle": "Modifiez ce fichier pour commencer."
          },
          {
            "type": "for",
            "in": "items",
            "as": "item",
            "child": {
              "type": "card",
              "child": {
                "type": "vstack",
                "spacing": 6,
                "padding": 14,
                "children": [
                  {
                    "type": "text",
                    "value": "{{ item.title }}",
                    "style": "title3"
                  },
                  {
                    "type": "text",
                    "value": "{{ item.body }}",
                    "style": "body",
                    "color": "secondary"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
