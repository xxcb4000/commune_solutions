{
  "screen": "feed",
  "navigation": {
    "title": "Actualités",
    "displayMode": "large"
  },
  "data": {
    "articles": "@articles"
  },
  "view": {
    "type": "scroll",
    "refreshable": true,
    "children": [
      {
        "type": "vstack",
        "spacing": 16,
        "padding": 16,
        "children": [
          {
            "type": "for",
            "in": "articles",
            "as": "article",
            "child": {
              "type": "card",
              "action": {
                "type": "navigate",
                "to": "detail",
                "with": {
                  "article": "{{ article }}"
                }
              },
              "child": {
                "type": "vstack",
                "spacing": 0,
                "children": [
                  {
                    "type": "image",
                    "url": "{{ article.imageUrl }}",
                    "aspectRatio": 1.78
                  },
                  {
                    "type": "vstack",
                    "spacing": 6,
                    "padding": 14,
                    "children": [
                      {
                        "type": "if",
                        "condition": "{{ article.isNew }}",
                        "then": {
                          "type": "text",
                          "value": "NOUVEAU",
                          "style": "badge"
                        }
                      },
                      {
                        "type": "text",
                        "value": "{{ article.title }}",
                        "style": "title3"
                      },
                      {
                        "type": "text",
                        "value": "{{ article.excerpt }}",
                        "style": "body",
                        "color": "secondary"
                      },
                      {
                        "type": "text",
                        "value": "{{ article.date }}",
                        "style": "caption",
                        "color": "tertiary"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
