rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // _config/* : tenant runtime config (modules activés, tabbar). Lu par
    // le preloader AVANT login, donc public read. Écriture réservée aux
    // admins (custom claim `admin: true`, set par script séparé sur les
    // users du dashboard).
    match /_config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Reste : lecture authentifiée, écriture refusée côté client.
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
