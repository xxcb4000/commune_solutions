rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // _config/* : tenant runtime config (modules activés, tabbar). Lu par
    // le preloader AVANT login, donc public read. Écriture réservée aux
    // admins (custom claim `admin: true`, set par script séparé sur les
    // users du dashboard).
    match /_config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // _moderation_queue/* : queue unifiée des contenus UGC en attente de
    // validation. Les CFs des modules officiels y écrivent via Admin SDK
    // (bypass rules). Le dashboard admin lit + supprime après approbation.
    // Le client mobile n'a aucun accès.
    match /_moderation_queue/{doc} {
      allow read, delete: if request.auth != null && request.auth.token.admin == true;
      allow create, update: if false;
    }

    // Collections de contenu officielles : lecture authentifiée pour les
    // citoyens, écriture réservée aux admins via le dashboard.
    // Les Cloud Functions officielles bypassent les rules (Admin SDK) et
    // peuvent donc écrire des sous-collections (votes, contacts, etc.)
    // sans whitelist ici.
    match /articles/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /events/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /polls/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /places/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /info/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Reste : lecture authentifiée, écriture refusée côté client.
    // Les CFs officielles écrivent via Admin SDK (bypass rules).
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
