rules_version = '2';

// Spike Phase 4c rules.
// Reads : ouvert aux utilisateurs authentifiés (FirebaseAuth).
// Writes : interdits côté client. Le seeding initial se fait via le script
// `tools/seed-firestore.py` (rules temporairement permissives) ou via l'admin
// SDK (à mettre en place pour le pipeline modules officiels).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
