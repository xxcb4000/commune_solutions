rules_version = '2';

// Firebase Storage rules — par projet commune.
//
// Le dashboard admin upload des images dans `uploads/<folder>/<filename>`
// (cf dashboard/app.js fonction uploadImage). L'auteur est un user
// authentifié avec custom claim `admin: true`. Les citoyens lisent les
// URLs publiques rendues par les modules.

service firebase.storage {
  match /b/{bucket}/o {
    // Upload + lecture autorisés sous `uploads/`. Les images se retrouvent
    // référencées par leur download URL dans Firestore (champ imageUrl
    // des articles, events, places, etc.).
    match /uploads/{folder}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Tout le reste est verrouillé par défaut.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
