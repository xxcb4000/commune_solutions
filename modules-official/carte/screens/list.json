{
  "screen": "list",
  "navigation": {
    "title": "Carte",
    "displayMode": "inline"
  },
  "data": {
    "places": "firestore:places"
  },
  "view": {
    "type": "scroll",
    "refreshable": true,
    "children": [
      {
        "type": "vstack",
        "spacing": 18,
        "padding": 18,
        "children": [
          {
            "type": "map",
            "in": "places",
            "as": "place",
            "latField": "lat",
            "lngField": "lng",
            "categoryField": "category",
            "height": 280,
            "action": {
              "type": "navigate",
              "to": "detail",
              "with": { "place": "{{ place }}" }
            }
          },
          {
            "type": "text",
            "value": "À proximité",
            "style": "serif-title",
            "color": "primary"
          },
          {
            "type": "for",
            "in": "places",
            "as": "place",
            "child": {
              "type": "card",
              "action": {
                "type": "navigate",
                "to": "detail",
                "with": { "place": "{{ place }}" }
              },
              "child": {
                "type": "hstack",
                "spacing": 14,
                "padding": 14,
                "align": "center",
                "children": [
                  {
                    "type": "image",
                    "systemName": "mappin.circle.fill",
                    "color": "civic",
                    "height": 26
                  },
                  {
                    "type": "vstack",
                    "spacing": 2,
                    "children": [
                      {
                        "type": "text",
                        "value": "{{ place.name }}",
                        "style": "serif-title2"
                      },
                      {
                        "type": "text",
                        "value": "{{ place.meta }}",
                        "style": "body",
                        "color": "secondary"
                      }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
