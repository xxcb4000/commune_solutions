{
  "screen": "list",
  "navigation": {
    "title": "Agenda",
    "displayMode": "inline"
  },
  "data": {
    "events": "firestore:events"
  },
  "view": {
    "type": "vstack",
    "spacing": 0,
    "fill": true,
    "children": [
      {
        "type": "segmented",
        "default": "calendar",
        "options": [
          { "id": "list", "label": "Liste" },
          { "id": "calendar", "label": "Calendrier" }
        ],
        "cases": {
          "calendar": {
            "type": "calendar",
            "in": "events",
            "dateField": "dateStart",
            "exposes": "selectedEvents",
            "child": {
              "type": "scroll",
              "children": [
                {
                  "type": "vstack",
                  "spacing": 12,
                  "padding": 16,
                  "children": [
                    {
                      "type": "text",
                      "value": "{{ selectedEventsDayLabel }}",
                      "style": "title3"
                    },
                    {
                      "type": "for",
                      "in": "selectedEvents",
                      "as": "event",
                      "child": {
                        "type": "card",
                        "action": {
                          "type": "navigate",
                          "to": "detail",
                          "with": {
                            "event": "{{ event }}"
                          }
                        },
                        "child": {
                          "type": "vstack",
                          "spacing": 0,
                          "children": [
                            {
                              "type": "image",
                              "url": "{{ event.imageUrl }}",
                              "aspectRatio": 1.78
                            },
                            {
                              "type": "vstack",
                              "spacing": 6,
                              "padding": 14,
                              "children": [
                                { "type": "text", "value": "{{ event.title }}", "style": "title3" },
                                { "type": "text", "value": "{{ event.date }}", "style": "body", "color": "secondary" },
                                { "type": "text", "value": "{{ event.location }}", "style": "caption", "color": "tertiary" }
                              ]
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              ]
            }
          },
          "list": {
            "type": "scroll",
            "children": [
              {
                "type": "vstack",
                "spacing": 16,
                "padding": 16,
                "children": [
                  {
                    "type": "for",
                    "in": "events",
                    "as": "event",
                    "child": {
                      "type": "card",
                      "action": {
                        "type": "navigate",
                        "to": "detail",
                        "with": {
                          "event": "{{ event }}"
                        }
                      },
                      "child": {
                        "type": "vstack",
                        "spacing": 0,
                        "children": [
                          {
                            "type": "image",
                            "url": "{{ event.imageUrl }}",
                            "aspectRatio": 1.78
                          },
                          {
                            "type": "vstack",
                            "spacing": 6,
                            "padding": 14,
                            "children": [
                              { "type": "text", "value": "{{ event.title }}", "style": "title3" },
                              { "type": "text", "value": "{{ event.date }}", "style": "body", "color": "secondary" },
                              { "type": "text", "value": "{{ event.location }}", "style": "caption", "color": "tertiary" }
                            ]
                          }
                        ]
                      }
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    ]
  }
}
