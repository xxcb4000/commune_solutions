{
  "screen": "list",
  "navigation": {
    "title": "Sondages",
    "displayMode": "inline"
  },
  "data": {
    "polls": "firestore:polls"
  },
  "view": {
    "type": "scroll",
    "refreshable": true,
    "children": [
      {
        "type": "vstack",
        "spacing": 16,
        "padding": 18,
        "children": [
          {
            "type": "for",
            "in": "polls",
            "as": "poll",
            "child": {
              "type": "card",
              "action": {
                "type": "navigate",
                "to": "detail",
                "with": { "poll": "{{ poll }}" }
              },
              "child": {
                "type": "vstack",
                "spacing": 8,
                "padding": 18,
                "children": [
                  {
                    "type": "text",
                    "value": "Consultation en cours",
                    "style": "eyebrow",
                    "color": "terra"
                  },
                  {
                    "type": "text",
                    "value": "{{ poll.title }}",
                    "style": "serif-title"
                  },
                  {
                    "type": "text",
                    "value": "{{ poll.description }}",
                    "style": "body",
                    "color": "secondary"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
