{
  "screen": "detail",
  "navigation": {
    "title": "",
    "displayMode": "inline"
  },
  "view": {
    "type": "scroll",
    "children": [
      {
        "type": "image",
        "url": "{{ article.imageUrl }}",
        "aspectRatio": 1.5
      },
      {
        "type": "vstack",
        "spacing": 14,
        "padding": 22,
        "children": [
          {
            "type": "text",
            "value": "{{ article.dateEyebrow }}",
            "style": "eyebrow",
            "color": "tertiary"
          },
          {
            "type": "text",
            "value": "{{ article.title }}",
            "style": "display-small"
          },
          {
            "type": "markdown",
            "value": "{{ article.body }}"
          }
        ]
      }
    ]
  }
}
