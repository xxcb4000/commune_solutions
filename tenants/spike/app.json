{
  "tenant": "spike",
  "firebase": "spike-1",
  "functionsBaseURL": "https://europe-west1-commune-spike-1.cloudfunctions.net",
  "modules": [
    { "id": "actualites", "version": "0.1.0" },
    { "id": "agenda", "version": "0.1.0" },
    { "id": "carte", "version": "0.1.0" },
    { "id": "sondages", "version": "0.1.0" },
    { "id": "info", "version": "0.1.0" }
  ],
  "view": {
    "type": "tabbar",
    "brand": {
      "label": "DÉMO A",
      "textColor": "#0f172a",
      "dots": ["#1976d2", "#26a69a", "#ffa000", "#ec407a", "#7e57c2", "#26c6da"]
